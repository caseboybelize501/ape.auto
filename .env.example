# APE - Autonomous Production Engineer
# Environment Configuration

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL=postgresql://ape_user:ape_password@localhost:5432/ape_db

# ===========================================
# REDIS (Celery broker & backend)
# ===========================================
REDIS_URL=redis://localhost:6379/0

# ===========================================
# GITHUB INTEGRATION
# ===========================================
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ===========================================
# GITLAB INTEGRATION
# ===========================================
GITLAB_TOKEN=glpat_your_gitlab_token
GITLAB_URL=https://gitlab.com

# ===========================================
# LLM PROVIDERS
# ===========================================
# Primary LLM (OpenAI)
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4-turbo-preview

# Fallback LLM (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key
ANTHROPIC_MODEL=claude-3-opus-20240229

# Local LLM (optional, for on-prem)
LOCAL_LLM_URL=http://localhost:8080/v1
LOCAL_LLM_API_KEY=local_key

# ===========================================
# CI/CD INTEGRATIONS
# ===========================================
JENKINS_URL=https://jenkins.yourcompany.com
JENKINS_USER=ape_bot
JENKINS_TOKEN=your_jenkins_token

ARGOCD_URL=https://argocd.yourcompany.com
ARGOCD_TOKEN=your_argocd_token

# ===========================================
# OBSERVABILITY STACK
# ===========================================
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key
DATADOG_SITE=datadoghq.com

GRAFANA_URL=https://grafana.yourcompany.com
GRAFANA_API_KEY=your_grafana_api_key

SENTRY_DSN=https://your_sentry_dsn@sentry.io/123456
SENTRY_ORG=your-org
SENTRY_API_KEY=your_sentry_api_key

# ===========================================
# ISSUE TRACKERS
# ===========================================
JIRA_URL=https://your-company.atlassian.net
JIRA_USER=ape_bot@yourcompany.com
JIRA_TOKEN=your_jira_api_token

LINEAR_API_KEY=your_linear_api_key

# ===========================================
# STORAGE (S3/Minio for artifacts)
# ===========================================
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET=ape-artifacts
S3_REGION=us-east-1

# For Minio (self-hosted):
# S3_ENDPOINT_URL=http://minio:9000

# ===========================================
# SECURITY
# ===========================================
SECRET_KEY=your_super_secret_key_for_jwt_signing_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ===========================================
# SERVER CONFIGURATION
# ===========================================
APE_HOST=0.0.0.0
APE_PORT=8000
APE_DEBUG=false
APE_LOG_LEVEL=info

# ===========================================
# CELERY CONFIGURATION
# ===========================================
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500

# ===========================================
# MONITORING
# ===========================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ===========================================
# FEATURE FLAGS
# ===========================================
APE_ENABLE_AUTO_DEPLOY=false
APE_ENABLE_AUTO_REPAIR=true
APE_MAX_REPAIR_ATTEMPTS=3
APE_CRITIC_TIMEOUT_SECONDS=300
